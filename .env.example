# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
MINIMAX_API_KEY=
OPENROUTER_API_KEY=

# 第三方中转 / 代理网关地址（可选）。设置后所有模型请求走此地址，
# 方便国内通过中转访问 Claude / OpenAI 等。Web UI 侧边栏也可直接填写。
# 例: BACKEND_URL=https://your-proxy.com/v1
BACKEND_URL=

# Web UI 访问口令（可选）：设了非空值则启用美观登录页，用户需输口令才能进 Web UI。
# 不设则无登录页（本地开发无感）。云部署建议设置以防陌生人盗用 API Key。
# 例: ACCESS_TOKEN=mySecretPass2026
ACCESS_TOKEN=

# Web UI 默认模型配置（可选）：登录后侧边栏默认选中，避免每次登录手动重选。
# DEFAULT_LLM_PROVIDER 取值: minimax/deepseek/qwen/glm/openai/anthropic/google/xai/openrouter/ollama
# 模型 ID 见 tradingagents/llm_clients/model_catalog.py，例（DeepSeek）:
# DEFAULT_LLM_PROVIDER=deepseek
# DEFAULT_QUICK_MODEL=deepseek-chat
# DEFAULT_DEEP_MODEL=deepseek-chat
DEFAULT_LLM_PROVIDER=
DEFAULT_QUICK_MODEL=
DEFAULT_DEEP_MODEL=

# 东财 push2 HTTP 代理（可选，云部署推荐）：阿里云等 IDC IP 会被东财 push2 封禁
# （资金流 fflow、行业对比 clist 等接口建连后 RemoteDisconnected），导致游资追踪
# 主力资金净流入与行业横向对比数据缺失。设此变量让东财请求走代理出口绕过。
# 国内住宅/移动 IP 代理最佳（IDC IP 可能也被东财封）。本地开发无需设置。
# 例: EM_HTTP_PROXY=http://user:pass@proxy.example.com:8080
EM_HTTP_PROXY=

# 巨量 IP 动态代理（可选，仅服务器使用）：未设置 EM_HTTP_PROXY 时，东财请求会按需
# 从此接口取一条 HTTP 代理；代理异常时自动换一条。此链接含签名，属于密钥，绝不可提交。
# 请只在服务器私有 .env 中填写：JULIANGIP_API_URL=http://...（不要填到本文件）
JULIANGIP_API_URL=
# 拉取动态代理失败时的最短重试间隔（秒），默认 5；通常无需修改。
EM_PROXY_REFRESH_MIN_INTERVAL=5

# Alpha 基准指数（可选，一般无需设置）：覆盖 benchmark_map 的自动检测，
# 所有 ticker 的 Alpha 计算统一使用此基准。不设则沪市→上证综指、深市→深证成指。
# 例: TRADINGAGENTS_BENCHMARK_TICKER=000300.SS
TRADINGAGENTS_BENCHMARK_TICKER=
