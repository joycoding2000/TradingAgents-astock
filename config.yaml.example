# =============================================================================
# TradingAgents-Astock 全局配置
# =============================================================================
# 将此文件复制为 config.yaml（已 .gitignore），按需修改参数。
# 未设置的项使用 tradingagents/default_config.py 中的默认值。
#
# 优先级（高 → 低）:
#   1. 环境变量 (TRADINGAGENTS_*)
#   2. config.yaml
#   3. default_config.py 硬编码默认值
# =============================================================================

# ── 输出语言 ──────────────────────────────────────────────────────────────────
# 分析师报告和最终结论的语言。内部 Agent 推理仍用英文以保障推理质量。
# 可选: Chinese, English
# output_language: Chinese

# ── 分析模式 ──────────────────────────────────────────────────────────────────
# full:  全部 7 位分析师
# fast:  仅运行技术 + 新闻 + 基本面 3 位（仍经过完整质量门控和下游风控）
# analysis_mode: full

# ── 辩论轮数 ──────────────────────────────────────────────────────────────────
# Bull/Bear 来回辩论的轮数。每轮 = Bull 发言 + Bear 发言各一次。
# 建议: 高性能模型 2 轮，弱模型 3 轮。超过 3 轮边际收益极低。
# max_debate_rounds: 2

# 风险讨论轮数（三个风险辩手之间的讨论）
# max_risk_discuss_rounds: 2

# ── 断点续跑 ──────────────────────────────────────────────────────────────────
# 启用后每个 graph node 保存状态到 SQLite，崩溃后可从上次节点恢复。
# 批量分析建议开启；单次快速分析建议关闭。
# checkpoint_enabled: false

# ── 记忆日志条目上限 ───────────────────────────────────────────────────────────
# 已完结条目的最大数，超过时删除最旧。null = 不限制。
# memory_log_max_entries: null

# ── LLM 提供商（默认值） ──────────────────────────────────────────────────────
# Web UI 和 CLI 的默认选择。用户可在运行时切换。
# llm_provider: openai
# deep_think_llm: gpt-5.4
# quick_think_llm: gpt-5.4-mini

# ── LLM 推理参数 ─────────────────────────────────────────────────────────────
# openai_reasoning_effort: null   # "medium", "high", "low"
# google_thinking_level: null     # "high", "minimal"
# anthropic_effort: null          # "high", "medium", "low"

# ── 第三方 API 代理 ──────────────────────────────────────────────────────────
# 也可通过环境变量 BACKEND_URL 或 Web UI 输入框设置。
# backend_url: null

# ── 数据源 ────────────────────────────────────────────────────────────────────
# 目前仅 "a_stock" 可用。Tushare 接入后会增加选项。
# data_vendors:
#   core_stock_apis: a_stock
#   technical_indicators: a_stock
#   fundamental_data: a_stock
#   news_data: a_stock
#   signal_data: a_stock

# ── 基准指数 ──────────────────────────────────────────────────────────────────
# 也可设 TRADINGAGENTS_BENCHMARK_TICKER 环境变量。
# benchmark_ticker: null

# ── 路径覆盖（对应环境变量） ──────────────────────────────────────────────────
#   TRADINGAGENTS_RESULTS_DIR   → results_dir（分析结果目录）
#   TRADINGAGENTS_CACHE_DIR     → data_cache_dir（数据缓存目录）
#   TRADINGAGENTS_MEMORY_LOG_PATH → memory_log_path（交易记忆日志路径）
